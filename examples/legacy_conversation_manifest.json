{
  "manifest_version": "1.0",
  "graph_id": "legacy_conversation_v1",
  "job_name": "legacy-conversation-demo",
  "entrypoints": ["visitor"],
  "initial_inputs": {
    "visitor": [
      {
        "text": "How do I reset my password?"
      }
    ]
  },
  "nodes": [
    {
      "node_id": "visitor",
      "agent_type": "visitor",
      "role": "root_coordinator"
    },
    {
      "node_id": "helper",
      "agent_type": "helper"
    },
    {
      "node_id": "policy",
      "agent_type": "policy",
      "config": {
        "approval_mode": "auto"
      }
    },
    {
      "node_id": "knowledge",
      "agent_type": "knowledge",
      "config": {
        "tool": "template",
        "template": "Suggested reply: please use the password reset link sent to your email."
      }
    },
    {
      "node_id": "sink",
      "agent_type": "collector",
      "config": {
        "complete_on_message": true
      }
    }
  ],
  "edges": [
    {
      "edge_id": "visitor_to_helper",
      "from_node": "visitor",
      "to_node": "helper",
      "message_type": "visitor_message"
    },
    {
      "edge_id": "helper_to_policy",
      "from_node": "helper",
      "to_node": "policy",
      "message_type": "policy_request"
    },
    {
      "edge_id": "policy_to_knowledge",
      "from_node": "policy",
      "to_node": "knowledge",
      "message_type": "knowledge_request"
    },
    {
      "edge_id": "knowledge_to_policy",
      "from_node": "knowledge",
      "to_node": "policy",
      "message_type": "knowledge_response"
    },
    {
      "edge_id": "policy_to_helper",
      "from_node": "policy",
      "to_node": "helper",
      "message_type": "policy_response"
    },
    {
      "edge_id": "helper_to_sink",
      "from_node": "helper",
      "to_node": "sink",
      "message_type": "helper_message"
    }
  ],
  "policies": {
    "recovery_mode": "local_restart"
  }
}
